#!/bin/sh
set -e

PLIST="/var/jb/Library/LaunchDaemons/com.procmonrootless.procmond.plist"
LABEL="com.procmonrootless.procmond"
LAUNCHCTL="/bin/launchctl"

if [ -x /var/jb/bin/launchctl ]; then
    LAUNCHCTL="/var/jb/bin/launchctl"
fi

if ! [ -x "$LAUNCHCTL" ]; then
    LAUNCHCTL="$(command -v launchctl || echo /bin/launchctl)"
fi

mkdir -p /var/jb/var/run
mkdir -p /var/jb/var/log
mkdir -p /var/mobile/Library/Caches/ProcMonRootless
mkdir -p /var/mobile/Library/Logs/ProcMonRootless
chmod 0777 /var/mobile/Library/Caches/ProcMonRootless || true
chmod 0777 /var/mobile/Library/Logs/ProcMonRootless || true

if [ -f "$PLIST" ]; then
    "$LAUNCHCTL" bootout system/$LABEL >/dev/null 2>&1 || true
    "$LAUNCHCTL" bootstrap system "$PLIST" >/dev/null 2>&1 || true
    "$LAUNCHCTL" enable system/$LABEL >/dev/null 2>&1 || true
    "$LAUNCHCTL" kickstart -k system/$LABEL >/dev/null 2>&1 || true
fi

/usr/bin/killall -9 SpringBoard >/dev/null 2>&1 || true
exit 0
